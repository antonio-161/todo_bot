# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Конфигурация базы данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todo_bot
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Конфигурация для инициализации базы данных
# Эти параметры используются для создания базы данных и таблиц при первом запуске
# Убедитесь, что они совпадают с настройками вашей базы данных
INIT_DB_USER=postgres
INIT_DB_PASS=your_admin_password
INIT_DB_HOST=localhost
INIT_DB_PORT=5432
INIT_DB_NAME=todo_bot
