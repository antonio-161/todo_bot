# .env

# Telegram Bot Token
BOT_TOKEN=8360861300:AAGGHAloefDbDAcLxayP7DJ-4YvJEycPwfg

# --- Переменные для инициализации PostgreSQL контейнера (используются сервисом 'postgres') ---
# Эти переменные используются официальным образом postgres для создания БД и пользователя при первом запуске.
POSTGRES_DB=todo_bot_dev # Имя базы данных, которую создаст контейнер Postgres
POSTGRES_USER=user_dev # Имя пользователя, которого создаст контейнер Postgres
POSTGRES_PASSWORD=2010 # Пароль для этого пользователя

# --- Переменные для подключения вашего БОТА к БД (используются вашим config.py) ---
# DB_HOST должен быть именем сервиса БД в docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=todo_bot_dev
DB_USER=user_dev
DB_PASSWORD=2010

# --- Переменные для инициализации БД из вашего config.py (если ваш бот сам инициализирует БД) ---
# Если ваш бот использует эти переменные для подключения с целью миграций/инициализации,
# они должны быть доступны. Часто они совпадают с основными учетными данными бота.
# Если ваш бот подключается к БД для инициализации с другими (например, админскими) правами,
# то здесь должны быть соответствующие значения.
INIT_DB_USER=user_dev # Или 'postgres', если бот использует админские права для инициализации
INIT_DB_PASS=2010 # Или 'your_admin_password_dev'
INIT_DB_HOST=postgres # Для бота, работающего в Docker, это всегда 'postgres'
INIT_DB_PORT=5432
INIT_DB_NAME=todo_bot_dev